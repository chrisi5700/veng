@PACKAGE_INIT@

# Package config for find_package(veng). Re-finds veng's public dependencies (the exported targets
# reference them, including the PRIVATE deps of the static libraries, which a consumer still links),
# then pulls in the exported targets and exposes the installed shader directory.
include(CMakeFindDependencyMacro)

find_dependency(Threads)
find_dependency(Vulkan)
find_dependency(glfw3 CONFIG)
find_dependency(glm CONFIG)
find_dependency(spdlog CONFIG)
find_dependency(slang)
find_dependency(vk-bootstrap CONFIG)
find_dependency(VulkanMemoryAllocator CONFIG)
find_dependency(unofficial-vulkan-memory-allocator-hpp CONFIG)
find_dependency(fastgltf CONFIG)
find_dependency(meshoptimizer CONFIG)
find_dependency(tinyobjloader CONFIG)
find_dependency(tinyply CONFIG)
find_dependency(lib3mf CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/vengTargets.cmake")

# Where veng's shipped shaders were installed. Point veng::Context's shader search paths here, or set
# the VENG_SHADER_DIR environment variable to it, so veng's built-in shaders (passes, etc.) resolve.
set_and_check(veng_SHADER_DIR "@PACKAGE_CMAKE_INSTALL_DATADIR@/veng/shaders")

check_required_components(veng)
