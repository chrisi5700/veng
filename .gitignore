# Ignore build directories
cmake-build-*/

# CLion-specific
.idea/
.idea/*
.idea/**

# Exclude project files (can be regenerated)
CMakeLists.txt.user
*.iml
.claude
# Ignore compiled binary files
*.out
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe

# Ignore CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Ignore generated testing files (like from Catch2 or gtest)
Testing/
test_output/

# Ignore generated benchmarking files
benchmark_output/

# Ignore any logs or temporary files
*.log
*.tmp

# Runtime log output — keep the directory, ignore its contents
/logs/*
!/logs/.gitkeep

# Ignore CLion workspace logs and directories
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries

# Ignore VSCode if you use it alongside CLion
.vscode/

# Build tree
build

# Fetched glTF sample models (see tests/assets/models.cmake)
tests/assets/models/

# Fetched CC0 steel PBR texture set for the stl_viewer example (see example/stl_viewer/steel.cmake)
example/stl_viewer/assets/

# Local scratchpad / backlog notes (not pushed)
notes.md
